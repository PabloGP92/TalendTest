    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="context.debtorQueryFilter = &quot;Factoring&quot;.equals(context.productType) ? &#xD;&#xA;&#x9;&#x9;&quot;Co-Borrower&quot; :&#xD;&#xA;&#x9;&#x9;&quot;Supplier&quot;;&#xD;&#xA;&#xD;&#xA;context.assignorQueryFilter = &quot;Factoring&quot;.equals(context.productType) ? &#xD;&#xA;&#x9;&#x9;&quot;Borrower&quot; :&#xD;&#xA;&#x9;&#x9;&quot;Confirming Client&quot;;&#xD;&#xA;&#xD;&#xA;//Build temp dir the same way as working jobs&#xD;&#xA;String tmpDir = System.getProperty(&quot;java.io.tmpdir&quot;);&#xD;&#xA;if (!tmpDir.endsWith(java.io.File.separator)) {&#xD;&#xA; tmpDir = tmpDir + java.io.File.separator;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Build file name and output path separately&#xD;&#xA;context.fileName = context.fileName + &quot;.xlsx&quot;;&#xD;&#xA;context.outputPath = tmpDir + context.fileName;&#xD;&#xA;&#xD;&#xA;//Debug output&#xD;&#xA;System.out.println(&quot;File name: &quot; + context.fileName);&#xD;&#xA;System.out.println(&quot;Output path: &quot; + context.outputPath);&#xD;&#xA;&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="Set variables"/>
