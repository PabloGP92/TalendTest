  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="40" posY="40">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="Date now = new Date();&#xD;&#xA;String datePart = new SimpleDateFormat(&quot;yyMMdd&quot;).format(now);&#xD;&#xA;String timePart = new SimpleDateFormat(&quot;HHmmss&quot;).format(now);&#xD;&#xA;&#xD;&#xA;String tmpDir = System.getProperty(&quot;java.io.tmpdir&quot;);&#xD;&#xA;if (!tmpDir.endsWith(java.io.File.separator)) {&#xD;&#xA;    tmpDir = tmpDir + java.io.File.separator;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;context.tmpDir = tmpDir;&#xD;&#xA;context.datePart = datePart;&#xD;&#xA;context.timePart = timePart;&#xD;&#xA;&#xD;&#xA;context.fileNameDEU = context.prefixDEU + datePart + &quot;.H&quot; + timePart + &quot;.csv&quot;;&#xD;&#xA;context.fileNameNotesDEU = context.fund1 + context.prefixDEU + datePart + &quot;.H&quot; + timePart + &quot;.csv&quot;;&#xD;&#xA;context.fileNameAllandaleDEU = context.fund2 + context.prefixDEU + datePart + &quot;.H&quot; + timePart + &quot;.csv&quot;;&#xD;&#xA;context.outputPathDEU = tmpDir + context.fileNameDEU;&#xD;&#xA;context.outputPathNotesDEU = tmpDir + context.fileNameNotesDEU;&#xD;&#xA;context.outputPathAllandaleDEU = tmpDir + context.fileNameAllandaleDEU;&#xD;&#xA;&#xD;&#xA;context.fileNameACR =  context.prefixACR + datePart + &quot;.H&quot; + timePart + &quot;.csv&quot;;&#xD;&#xA;context.fileNameNotesACR = context.fund1 + context.prefixACR + datePart + &quot;.H&quot; + timePart + &quot;.csv&quot;;&#xD;&#xA;context.fileNameAllandaleACR = context.fund2 + context.prefixACR + datePart + &quot;.H&quot; + timePart + &quot;.csv&quot;;&#xD;&#xA;context.outputPathACR = tmpDir + context.fileNameACR;&#xD;&#xA;context.outputPathNotesACR = tmpDir + context.fileNameNotesACR;&#xD;&#xA;context.outputPathAllandaleACR = tmpDir + context.fileNameAllandaleACR;&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;Temp dir: &quot; + tmpDir);&#xD;&#xA;System.out.println(&quot;Date part: &quot; + datePart);&#xD;&#xA;System.out.println(&quot;Time part: &quot; + timePart);&#xD;&#xA;System.out.println(&quot;roleCompartmentFund: &quot; + context.roleCompartmentFund);&#xD;&#xA;System.out.println(&quot;fundNames: &quot; + context.fundNames);&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;fileNameNotesDEU: &quot; + context.fileNameNotesDEU);&#xD;&#xA;System.out.println(&quot;fileNameAllandaleDEU: &quot; + context.fileNameAllandaleDEU);&#xD;&#xA;System.out.println(&quot;outputPathNotesDEU: &quot; + context.outputPathNotesDEU);&#xD;&#xA;System.out.println(&quot;outputPathAllandaleDEU: &quot; + context.outputPathAllandaleDEU);&#xD;&#xA;&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
