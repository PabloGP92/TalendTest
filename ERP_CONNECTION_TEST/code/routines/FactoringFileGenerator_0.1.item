package routines;

import java.text.SimpleDateFormat;
import java.util.Date;

/**
 * Talend Java Routine: FactoringFileGenerator
 *
 * Builds positional flat file names and record lines for the
 * DEU (Debtor) and ACR (Creditor) Factoring files.
 *
 * All Salesforce data is expected to be queried upstream via
 * tSalesforceInput components and passed in as plain strings.
 *
 * USAGE FROM tJava:
 *
 *   // Build filename once at job start:
 *   String deuFileName = FactoringFileGenerator.buildFileName("DEU");
 *   String acrFileName = FactoringFileGenerator.buildFileName("ACR");
 *
 *   // Build one DEU line per debtor row (inside tJava in the debtor flow):
 *   String line = FactoringFileGenerator.buildDeuLine(
 *       row1.TWC_Document__c,           // ID_DEUDOR
 *       row1.AccountName,               // NOMBRE
 *       row1.TWC_CNAE_Code__r_Name,     // GRUPO_CNAE
 *       row1.BillingPostalCode,         // CODIGO_POSTAL
 *       row1.TWC_Defaulted_Account__c,  // IMPAGO  (boolean as String "true"/"false")
 *       row1.LLC_BI__Booked_Date__c,    // FECHA_TOMA_RAZON (YYYY-MM-DD)
 *       row1.BillingCountry,            // PAIS
 *       row1.CreditorDocument,          // ID_ACREEDOR (from creditor account)
 *       row1.TWC_Grade__c,              // GRADE_EULER
 *       row1.TWC_Sales_Volume__c,       // VOLUMEN_VENTAS
 *       row1.TWC_D_B_Rating__c,         // RATING D&B
 *       row1.TWC_Code__c,               // DEDUORTWC
 *       row1.HouseholdCode,             // GRUPO
 *       row1.TWC_SIC__c,                // SIC
 *       row1.TWC_CodAllianz__c,         // DEUDOREULER
 *       row1.TWC_Cartan__c,             // DEUDORCARTAN
 *       row1.HouseholdName              // NOMBRE_GRUPO
 *   );
 *
 *   // Build one ACR line per creditor row (inside tJava in the creditor flow):
 *   String line = FactoringFileGenerator.buildAcrLine(
 *       row2.TWC_Document__c,           // ID_ACREEDOR
 *       row2.AccountName,               // NOMBRE
 *       row2.TWC_CNAE_Code__r_Name,     // GRUPO_CNAE
 *       row2.BillingPostalCode,         // CODIGO_POSTAL
 *       row2.BillingCountry,            // PAIS
 *       row2.TWC_Code__c,               // ACREEDORTWC
 *       row2.HouseholdCode,             // GRUPO
 *       row2.TWC_SIC__c,                // SIC
 *       row2.HouseholdName              // NOMBRE_GRUPO
 *   );
 */
public class FactoringFileGenerator {

    private static final String FUND_PREFIX    = "TITU7325_CA9986";
    private static final int    DEU_RECORD_LENGTH = 475;
    private static final int    ACR_RECORD_LENGTH = 373;


    // =======================================================
    //  FILE NAME
    // =======================================================

    /**
     * Builds the output filename for the given file type.
     * Pattern: {type}_TITU7325_CA9986_F{YYMMDD}_H{HHmmss}.txt
     * Example: DEU_TITU7325_CA9986_F250918_H161111.txt
     *
     * @param fileType  "DEU" or "ACR"
     */
    public static String buildFileName(String fileType) {
        Date now = new Date();
        String datePart = new SimpleDateFormat("yyMMdd").format(now);
        String timePart = new SimpleDateFormat("HHmmss").format(now);
        return fileType + "_" + FUND_PREFIX + "_F" + datePart + "_H" + timePart + ".txt";
    }


    // =======================================================
    //  DEU LINE BUILDER  (total = 475 chars)
    // =======================================================
    /**
     * Builds one positional DEU (Debtor) record.
     *
     * Field layout (1-based positions):
     *   Pos   1 -   8  (  8)  FECHA_DATOS       Today YYYYMMDD (auto-generated)
     *   Pos   9 -  43  ( 35)  ID_DEUDOR         Account.TWC_Document__c
     *   Pos  44 - 193  (150)  NOMBRE            Account.Name
     *   Pos 194 - 196  (  3)  GRUPO_CNAE        Account.TWC_CNAE_Code__r.Name
     *   Pos 197 - 205  (  9)  CODIGO_POSTAL     Account.BillingPostalCode
     *   Pos 206 - 206  (  1)  IMPAGO            Account.TWC_Defaulted_Account__c (1/0)
     *   Pos 207 - 214  (  8)  FECHA_TOMA_RAZON  LLC_BI__Loan__c.LLC_BI__Booked_Date__c
     *   Pos 215 - 217  (  3)  PAIS              Account.BillingCountry
     *   Pos 218 - 252  ( 35)  ID_ACREEDOR       Creditor Account.TWC_Document__c
     *   Pos 253 - 254  (  2)  GRADE_EULER       Account.TWC_Grade__c
     *   Pos 255 - 266  ( 12)  VOLUMEN_VENTAS    Account.TWC_Sales_Volume__c
     *   Pos 267 - 270  (  4)  RATING_DB         Account.TWC_D_B_Rating__c
     *   Pos 271 - 275  (  5)  DEDUORTWC         Account.TWC_Code__c
     *   Pos 276 - 281  (  6)  GRUPO             Household connected-from name (6 chars)
     *   Pos 282 - 285  (  4)  SIC               Account.TWC_SIC__c
     *   Pos 286 - 305  ( 20)  DEUDOREULER       Account.TWC_CodAllianz__c
     *   Pos 306 - 325  ( 20)  DEUDORCARTAN      Account.TWC_Cartan__c
     *   Pos 326 - 475  (150)  NOMBRE_GRUPO      Household connected-from full name
     */
    public static String buildDeuLine(
            String idDeudor,
            String nombre,
            String grupoCnae,
            String codigoPostal,
            String impago,
            String fechaTomRazon,
            String pais,
            String idAcreedor,
            String gradeEuler,
            String volumenVentas,
            String ratingDB,
            String deudorTwc,
            String grupo,
            String sic,
            String deudorEuler,
            String deudorCartan,
            String nombreGrupo) {

        StringBuilder sb = new StringBuilder(DEU_RECORD_LENGTH);

        appendAlpha(sb, today(),                        8);   //   1-  8  FECHA_DATOS
        appendAlpha(sb, idDeudor,                      35);   //   9- 43  ID_DEUDOR
        appendAlpha(sb, nombre,                       150);   //  44-193  NOMBRE
        appendAlpha(sb, grupoCnae,                      3);   // 194-196  GRUPO_CNAE
        appendAlpha(sb, codigoPostal,                   9);   // 197-205  CODIGO_POSTAL
        sb.append(toImpago(impago));                           // 206      IMPAGO
        appendAlpha(sb, toDate(fechaTomRazon),          8);   // 207-214  FECHA_TOMA_RAZON
        appendAlpha(sb, COUNTRY_CODES.get(pais),        3);   // 215-217  PAIS
        appendAlpha(sb, idAcreedor,                    35);   // 218-252  ID_ACREEDOR
        appendAlpha(sb, toInt(gradeEuler),              2);   // 253-254  GRADE_EULER
        appendVolumenVentas(sb, volumenVentas,         12);   // 255-266  VOLUMEN_VENTAS
        appendAlpha(sb, ratingDB,                       4);   // 267-270  RATING_DB
        appendAlpha(sb, deudorTwc,                      5);   // 271-275  DEDUORTWC
        appendAlpha(sb, grupo,                          6);   // 276-281  GRUPO
        appendAlpha(sb, toInt(sic),                     4);   // 282-285  SIC
        appendAlpha(sb, toInt(deudorEuler),            20);   // 286-305  DEUDOREULER
        appendAlpha(sb, toInt(deudorCartan),           20);   // 306-325  DEUDORCARTAN
        appendAlpha(sb, nombreGrupo,                  150);   // 326-475  NOMBRE_GRUPO
        
        return padOrTruncate(sb.toString(), DEU_RECORD_LENGTH);
    }


    // =======================================================
    //  ACR LINE BUILDER  (total = 373 chars)
    // =======================================================
    /**
     * Builds one positional ACR (Creditor) record.
     *
     * Field layout (1-based positions):
     *   Pos   1 -   8  (  8)  FECHA_DATOS    Today YYYYMMDD (auto-generated)
     *   Pos   9 -  43  ( 35)  ID_ACREEDOR    Account.TWC_Document__c
     *   Pos  44 - 193  (150)  NOMBRE         Account.Name
     *   Pos 194 - 196  (  3)  GRUPO_CNAE     Account.TWC_CNAE_Code__r.Name
     *   Pos 197 - 205  (  9)  CODIGO_POSTAL  Account.BillingPostalCode
     *   Pos 206 - 208  (  3)  PAIS           Account.BillingCountry
     *   Pos 209 - 213  (  5)  ACREEDORTWC    Account.TWC_Code__c
     *   Pos 214 - 219  (  6)  GRUPO          Household connected-from name (6 chars)
     *   Pos 220 - 223  (  4)  SIC            Account.TWC_SIC__c
     *   Pos 224 - 373  (150)  NOMBRE_GRUPO   Household connected-from full name
     */
    public static String buildAcrLine(
            String idAcreedor,
            String nombre,
            String grupoCnae,
            String codigoPostal,
            String pais,
            String acreedorTwc,
            String grupo,
            String sic,
            String nombreGrupo) {

        StringBuilder sb = new StringBuilder(ACR_RECORD_LENGTH);

        appendAlpha(sb, today(),       8);   //   1-  8  FECHA_DATOS
        appendAlpha(sb, idAcreedor,   35);   //   9- 43  ID_ACREEDOR
        appendAlpha(sb, nombre,      150);   //  44-193  NOMBRE
        appendAlpha(sb, grupoCnae,     3);   // 194-196  GRUPO_CNAE
        appendAlpha(sb, codigoPostal,  9);   // 197-205  CODIGO_POSTAL
        appendAlpha(sb, COUNTRY_CODES.get(pais), 3);   // 206-208  PAIS
        appendAlpha(sb, acreedorTwc,   5);   // 209-213  ACREEDORTWC
        appendAlpha(sb, grupo,         6);   // 214-219  GRUPO
        appendAlpha(sb, toInt(sic),    4);   // 220-223  SIC
        appendAlpha(sb, nombreGrupo, 150);   // 224-373  NOMBRE_GRUPO

        return padOrTruncate(sb.toString(), ACR_RECORD_LENGTH);
    }


    // =======================================================
    //  PRIVATE HELPERS
    // =======================================================

    /** Returns today as YYYYMMDD. */
    private static String today() {
        return new SimpleDateFormat("yyyyMMdd").format(new Date());
    }

    /**
     * Converts a Salesforce date (YYYY-MM-DD) to YYYYMMDD.
     * Returns 8 spaces if null or empty.
     */
    private static String toDate(String sfDate) {
        if (sfDate == null || sfDate.trim().isEmpty()) return "        ";
        return sfDate.trim().replace("-", "").substring(0, 8);
    }

    /**
     * Converts a boolean-as-string to "1" (true) or "0" (false).
     * Handles "true"/"false" strings from Salesforce.
     */
    private static char toImpago(String value) {
        return "true".equalsIgnoreCase(value == null ? "" : value.trim()) ? '1' : '0';
    }

    /**
     * Converts a Salesforce Double field (e.g. "1234.0") to a plain integer string.
     * Returns empty string for null or unparseable input.
     */
    private static String toInt(String raw) {
        if (raw == null || raw.trim().isEmpty()) return "";
        try {
            return String.valueOf(Math.round(Double.parseDouble(raw.trim())));
        } catch (NumberFormatException e) {
            return raw.trim();
        }
    }

    /**
     * Left-aligns value in a field of exactly size characters, space-padded on the right.
     * Truncates if longer than size. Null treated as empty.
     */
    private static void appendAlpha(StringBuilder sb, String value, int size) {
        String v = value == null ? "" : value.trim();
        if (v.length() > size) v = v.substring(0, size);
        sb.append(v);
        for (int i = v.length(); i < size; i++) sb.append(' ');
    }

    /**
     * Formats VOLUMEN_VENTAS: sign character (+/-) followed by zero-padded digits.
     * Total width = 12. Example: 490866 -> "+00000490866"
     * Fills with spaces if value is null or unparseable.
     */
    private static void appendVolumenVentas(StringBuilder sb, String raw, int size) {
        if (raw == null || raw.trim().isEmpty()) {
            for (int i = 0; i < size; i++) sb.append(' ');
            return;
        }
        try {
            long val = Math.round(Double.parseDouble(raw.trim()));
            String digits = String.format("%0" + size + "d", Math.abs(val));
            if (digits.length() > size) digits = digits.substring(digits.length() - size);
            sb.append(digits);
        } catch (NumberFormatException e) {
            for (int i = 0; i < size; i++) sb.append(' ');
        }
    }

    /** Pads with spaces or truncates to exactly targetLength characters. */
    private static String padOrTruncate(String s, int targetLength) {
        if (s.length() == targetLength) return s;
        if (s.length() > targetLength)  return s.substring(0, targetLength);
        StringBuilder sb = new StringBuilder(s);
        while (sb.length() < targetLength) sb.append(' ');
        return sb.toString();
    }
    
