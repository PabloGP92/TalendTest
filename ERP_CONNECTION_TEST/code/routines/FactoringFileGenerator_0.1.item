    /**
     * Looks up the 3-digit country code for the given Salesforce BillingCountry value.
     * The input is matched case-insensitively and trimmed.
     * Returns "958" (OTROS PAISES NO RELACIONADOS) if not found.
     */
    public static String getCountryCode(String billingCountry) {
        if (billingCountry == null || billingCountry.trim().isEmpty()) return "   ";
        String key = billingCountry.trim().toUpperCase();
        String code = COUNTRY_CODES.get(key);
        return code != null ? code : "958";
    }
}
