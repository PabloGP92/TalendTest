  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="40" posY="80">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="context.debtorQueryFilter = &quot;Factoring&quot;.equals(context.productType) ?&#xD;&#xA;        &quot;Co-Borrower&quot; :&#xD;&#xA;        &quot;Confirming Client&quot;;&#xD;&#xA;&#xD;&#xA;context.creditorQueryFilter = &quot;Reverse Factoring&quot;.equals(context.productType) ?&#xD;&#xA;        &quot;Borrower&quot; :&#xD;&#xA;        &quot;Supplier&quot;;&#xD;&#xA;&#xD;&#xA;// Build temp dir&#xD;&#xA;String tmpDir = System.getProperty(&quot;java.io.tmpdir&quot;);&#xD;&#xA;if (!tmpDir.endsWith(java.io.File.separator)) {&#xD;&#xA;    tmpDir = tmpDir + java.io.File.separator;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Date formatters&#xD;&#xA;java.text.SimpleDateFormat sdf1Short = new java.text.SimpleDateFormat(&quot;yyMMdd&quot;);&#xD;&#xA;java.text.SimpleDateFormat sdf2      = new java.text.SimpleDateFormat(&quot;HHmmss&quot;);&#xD;&#xA;java.text.SimpleDateFormat sdf3      = new java.text.SimpleDateFormat(&quot;ddMMyyyy&quot;);&#xD;&#xA;java.text.SimpleDateFormat pfxFmt    = new java.text.SimpleDateFormat(&quot;dd_MM_yyyy_HH_mm_ss&quot;);&#xD;&#xA;&#xD;&#xA;java.util.Date now = new java.util.Date();&#xD;&#xA;// Replace with context.batchDate if fechaope comes from the query&#xD;&#xA;java.util.Date fechaope = now;&#xD;&#xA;&#xD;&#xA;String pfx        = pfxFmt.format(fechaope) + &quot;_&quot;;&#xD;&#xA;String sdf1ShortS = sdf1Short.format(now);&#xD;&#xA;String sdf2S      = sdf2.format(now);&#xD;&#xA;String sdf3S      = sdf3.format(now);&#xD;&#xA;&#xD;&#xA;// --- IE2 compartments (positional CSV files) ---&#xD;&#xA;String baseFT3 = pfx + &quot;OFE.TITU7330.CA9986.F&quot; + sdf1ShortS + &quot;.H&quot;;&#xD;&#xA;String baseFT4 = pfx + &quot;OFE.TITU7337.CA9986.F&quot; + sdf1ShortS + &quot;.H&quot;;&#xD;&#xA;String baseFT5 = pfx + &quot;OFE.TITU7343.CA9986.F&quot; + sdf1ShortS + &quot;.H&quot;;&#xD;&#xA;&#xD;&#xA;context.fileName_FT3 = baseFT3 + &quot;.csv&quot;;&#xD;&#xA;context.fileName_FT4 = baseFT4 + &quot;.csv&quot;;&#xD;&#xA;context.fileName_FT5 = baseFT5 + &quot;.csv&quot;;&#xD;&#xA;&#xD;&#xA;context.responseFileName_FT3 = baseFT3.replace(&quot;_OFE.&quot;, &quot;_TAS.&quot;) + &quot;.txt&quot;;&#xD;&#xA;context.responseFileName_FT4 = baseFT4.replace(&quot;_OFE.&quot;, &quot;_TAS.&quot;) + &quot;.txt&quot;;&#xD;&#xA;context.responseFileName_FT5 = baseFT5.replace(&quot;_OFE.&quot;, &quot;_TAS.&quot;) + &quot;.txt&quot;;&#xD;&#xA;&#xD;&#xA;context.outputPath_FT3 = tmpDir + context.fileName_FT3;&#xD;&#xA;context.outputPath_FT4 = tmpDir + context.fileName_FT4;&#xD;&#xA;context.outputPath_FT5 = tmpDir + context.fileName_FT5;&#xD;&#xA;&#xD;&#xA;context.fileName_ALLANDALE         = &quot;GLOBALREC OFFER FILE_&quot; + sdf3S + &quot;.csv&quot;;&#xD;&#xA;context.responseFileName_ALLANDALE = context.fileName_ALLANDALE;&#xD;&#xA;context.outputPath_ALLANDALE       = tmpDir + context.fileName_ALLANDALE;&#xD;&#xA;&#xD;&#xA;// Debug&#xD;&#xA;System.out.println(&quot;FT3: &quot; + context.outputPath_FT3);&#xD;&#xA;System.out.println(&quot;FT4: &quot; + context.outputPath_FT4);&#xD;&#xA;System.out.println(&quot;FT5: &quot; + context.outputPath_FT5);&#xD;&#xA;System.out.println(&quot;ALLANDALE: &quot; + context.outputPath_ALLANDALE);"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="Set variables"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
