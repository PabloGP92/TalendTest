  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="440" posY="280">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="String rawLine = (String) globalMap.get(&quot;tFTPFileList_1_CURRENT_FILE&quot;);&#xD;&#xA;String filePath = (String) globalMap.get(&quot;tFTPFileList_1_CURRENT_FILEPATH&quot;);&#xD;&#xA;&#xD;&#xA;String[] parts = rawLine.trim().split(&quot;\\s+&quot;);&#xD;&#xA;&#xD;&#xA;// Explicitly append GMT to ensure correct timezone parsing&#xD;&#xA;String dateStr = parts[4] + &quot; &quot; + parts[5] + &quot; &quot; + parts[6] + &quot; &quot; + parts[7] + &quot; &quot; + parts[8] + &quot; GMT&quot;;&#xD;&#xA;&#xD;&#xA;java.text.SimpleDateFormat sdf = new java.text.SimpleDateFormat(&quot;EEE, dd MMM yyyy HH:mm:ss z&quot;, java.util.Locale.ENGLISH);&#xD;&#xA;sdf.setTimeZone(java.util.TimeZone.getTimeZone(&quot;GMT&quot;));&#xD;&#xA;java.util.Date fileDate = sdf.parse(dateStr);&#xD;&#xA;&#xD;&#xA;java.util.Calendar calNow = java.util.Calendar.getInstance(java.util.TimeZone.getTimeZone(&quot;UTC&quot;));&#xD;&#xA;long nowUTC = calNow.getTimeInMillis();&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;DATE STR parsed: &quot; + dateStr);&#xD;&#xA;System.out.println(&quot;fileDate ms:     &quot; + fileDate.getTime());&#xD;&#xA;System.out.println(&quot;nowUTC ms:       &quot; + nowUTC);&#xD;&#xA;System.out.println(&quot;difference (min):&quot; + ((nowUTC - fileDate.getTime()) / 60000) + &quot; minutes ago&quot;);&#xD;&#xA;&#xD;&#xA;boolean isRecent = fileDate.getTime() >= (nowUTC - 3600000L);&#xD;&#xA;&#xD;&#xA;String fullFileName = filePath.substring(filePath.lastIndexOf(&quot;/&quot;) + 1);&#xD;&#xA;//String fileName = fullFileName.contains(&quot;.&quot;) ? fullFileName.substring(0, fullFileName.lastIndexOf(&quot;.&quot;)) : fullFileName;&#xD;&#xA;String fileName = filePath.substring(filePath.lastIndexOf(&quot;/&quot;) + 1);&#xD;&#xA;output_row.fileName = fileName;&#xD;&#xA;output_row.filePath = filePath;&#xD;&#xA;output_row.isRecent = isRecent;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaRow_1">
      <column comment="" key="false" length="-1" name="fileName" nullable="true" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="filePath" nullable="true" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="isRecent" nullable="true" pattern="&quot;dd-MM-yyyy&quot;" precision="-1" sourceType="" type="id_Boolean" originalLength="-1" usefulColumn="true"/>
    </metadata>
  </node>
