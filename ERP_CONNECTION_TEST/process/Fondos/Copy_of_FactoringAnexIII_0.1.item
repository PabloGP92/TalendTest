  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="120" posY="40">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="Date now = new Date();&#xD;&#xA;String datePart = new SimpleDateFormat(&quot;yyMMdd&quot;).format(now);&#xD;&#xA;String timePart = new SimpleDateFormat(&quot;HHmmss&quot;).format(now);&#xD;&#xA;&#xD;&#xA;String tmpDir = System.getProperty(&quot;java.io.tmpdir&quot;);&#xD;&#xA;if (!tmpDir.endsWith(java.io.File.separator)) {&#xD;&#xA;    tmpDir = tmpDir + java.io.File.separator;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;context.fileNameDEU = context.prefixDEU + datePart + &quot;.H&quot; + timePart + &quot;.txt&quot;;&#xD;&#xA;context.outputPathDEU = tmpDir + context.fileNameDEU;&#xD;&#xA;&#xD;&#xA;context.fileNameACR = context.prefixACR + datePart + &quot;.H&quot; + timePart + &quot;.txt&quot;;&#xD;&#xA;context.outputPathACR = tmpDir + context.fileNameACR;&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;Temp dir: &quot; + tmpDir);&#xD;&#xA;System.out.println(&quot;File name DEU: &quot; + context.fileNameDEU);&#xD;&#xA;System.out.println(&quot;Output path DEU: &quot; + context.outputPathDEU);&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
